# Trinetra SEO — environment variables
# Copy to .env for local dev. On Render, set these in the dashboard / render.yaml.

# Shopify app credentials (from the Dev Dashboard → app → API credentials)
SHOPIFY_API_KEY=your_client_id
SHOPIFY_API_SECRET=your_client_secret

# Access scopes (must match shopify.app.toml)
SCOPES=read_products,write_products,read_content,write_content,read_online_store_navigation,write_online_store_navigation

# Public URL where the app is hosted (Render URL in production; CLI sets tunnel in dev)
SHOPIFY_APP_URL=https://trinetra-seo.onrender.com

# Postgres connection string (Neon). Use the pooled connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
