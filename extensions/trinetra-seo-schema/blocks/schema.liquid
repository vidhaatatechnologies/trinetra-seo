{%- comment -%}
  Trinetra SEO – Structured Data (JSON-LD)
  App embed block. Injects schema.org markup into <head> based on the current
  template. Reads native Liquid objects (product, collection, article, shop) so
  no API writes or extra scopes are required. Toggle each schema type below in
  the theme editor.
{%- endcomment -%}

{%- if block.settings.enable_organization -%}
  {%- assign org_name = block.settings.org_name | default: shop.name -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ org_name | json }},
    "url": {{ shop.url | json }}
    {%- if block.settings.org_logo != blank %},
    "logo": {{ block.settings.org_logo | image_url: width: 512 | prepend: "https:" | json }}
    {%- elsif shop.brand.logo %},
    "logo": {{ shop.brand.logo | image_url: width: 512 | json }}
    {%- endif -%}
    {%- if block.settings.org_twitter != blank or block.settings.org_facebook != blank %},
    "sameAs": [
      {%- assign sep = "" -%}
      {%- if block.settings.org_twitter != blank -%}{{ block.settings.org_twitter | json }}{%- assign sep = "," -%}{%- endif -%}
      {%- if block.settings.org_facebook != blank -%}{{ sep }}{{ block.settings.org_facebook | json }}{%- endif -%}
    ]
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- if block.settings.enable_website and template.name == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{%- endif -%}

{%- if block.settings.enable_product and template.name == 'product' and product -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ product.url | prepend: shop.url | json }},
    {%- if product.images.size > 0 %}
    "image": [
      {%- for image in product.images limit: 10 -%}
        {{ image | image_url: width: 1200 | prepend: "https:" | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ],
    {%- endif %}
    "description": {{ product.description | strip_html | truncate: 5000 | json }},
    {%- if product.vendor != blank %}
    "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
    {%- endif %}
    {%- if current_variant.sku != blank %}
    "sku": {{ current_variant.sku | json }},
    {%- endif %}
    "offers": {
      "@type": "Offer",
      "url": {{ product.url | prepend: shop.url | json }},
      "priceCurrency": {{ shop.currency | json }},
      "price": "{{ current_variant.price | divided_by: 100.0 }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
    }
  }
  </script>
{%- endif -%}

{%- if block.settings.enable_breadcrumb and template.name == 'product' and product -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} },
      {%- if collection %}
      { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ collection.url | prepend: shop.url | json }} },
      { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }} }
      {%- else %}
      { "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }} }
      {%- endif %}
    ]
  }
  </script>
{%- endif -%}

{%- if block.settings.enable_article and template.name == 'article' and article -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ article.title | json }},
    "url": {{ article.url | prepend: shop.url | json }},
    {%- if article.image %}
    "image": [ {{ article.image | image_url: width: 1200 | prepend: "https:" | json }} ],
    {%- endif %}
    "datePublished": {{ article.published_at | date: "%Y-%m-%dT%H:%M:%SZ" | json }},
    "dateModified": {{ article.updated_at | date: "%Y-%m-%dT%H:%M:%SZ" | json }},
    "author": { "@type": "Person", "name": {{ article.author | json }} },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
      {%- if shop.brand.logo %},
      "logo": { "@type": "ImageObject", "url": {{ shop.brand.logo | image_url: width: 512 | json }} }
      {%- endif %}
    },
    "description": {{ article.excerpt_or_content | strip_html | truncate: 5000 | json }}
  }
  </script>
{%- endif -%}

{%- comment -%} FAQ: rendered when the page/product has a `trinetra_seo.faq` JSON metafield (list of {q,a}). {%- endcomment -%}
{%- if block.settings.enable_faq -%}
  {%- assign faq_data = nil -%}
  {%- if template.name == 'product' and product.metafields.trinetra_seo.faq %}{%- assign faq_data = product.metafields.trinetra_seo.faq.value -%}{%- endif -%}
  {%- if template.name == 'page' and page.metafields.trinetra_seo.faq %}{%- assign faq_data = page.metafields.trinetra_seo.faq.value -%}{%- endif -%}
  {%- if faq_data -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for item in faq_data -%}
      {
        "@type": "Question",
        "name": {{ item.q | json }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | strip_html | json }} }
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Trinetra SEO Schema",
  "target": "head",
  "settings": [
    { "type": "header", "content": "Structured data (JSON-LD)" },
    { "type": "paragraph", "content": "Enable rich-result schema for your storefront. Powered by Trinetra SEO." },
    { "type": "checkbox", "id": "enable_organization", "label": "Organization schema", "default": true },
    { "type": "checkbox", "id": "enable_website", "label": "WebSite + Sitelinks search box (home page)", "default": true },
    { "type": "checkbox", "id": "enable_product", "label": "Product schema (product pages)", "default": true },
    { "type": "checkbox", "id": "enable_breadcrumb", "label": "Breadcrumb schema (product pages)", "default": true },
    { "type": "checkbox", "id": "enable_article", "label": "Article schema (blog posts)", "default": true },
    { "type": "checkbox", "id": "enable_faq", "label": "FAQ schema (from trinetra_seo.faq metafield)", "default": false },
    { "type": "header", "content": "Organization details" },
    { "type": "text", "id": "org_name", "label": "Organization name", "info": "Defaults to your store name." },
    { "type": "image_picker", "id": "org_logo", "label": "Organization logo" },
    { "type": "text", "id": "org_twitter", "label": "Twitter/X profile URL" },
    { "type": "text", "id": "org_facebook", "label": "Facebook page URL" }
  ]
}
{% endschema %}
